NODE_ENV=development
PORT=4000

# Postgres
DATABASE_URL=postgres://gold_wallet:changeme@localhost:5432/gold_wallet_dev

# Redis (sessions, rate limiting, caching price/gas data)
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=replace_with_random_64_byte_hex
JWT_REFRESH_SECRET=replace_with_a_different_random_64_byte_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# 2FA
TOTP_ISSUER=GoldWallet

# RPC providers — used ONLY for read endpoints (balances, gas, price caching)
# and for the optional broadcast-proxy endpoint. Server never has any
# access to user private keys or signing capability.
INFURA_PROJECT_ID=
ALCHEMY_POLYGON_KEY=
BNB_RPC_URL=https://bsc-dataseed.binance.org

# Push notifications
FIREBASE_SERVICE_ACCOUNT_JSON=

# Price feed
COINGECKO_API_KEY=
